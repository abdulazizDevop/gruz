rules_version = '2';

// DoorMan Firestore rules.
//
// The app uses custom auth (name+password stored in the `users` collection),
// not Firebase Auth, so `request.auth` is always null here. To stay simple
// while supporting role-based access, rules are open. Hardening path: add
// Firebase Anonymous Auth in the client, then gate writes on `request.auth`.
//
// Paste this into Firebase Console → Firestore Database → Rules and click
// "Publish" whenever this file changes. The file in the repo is the source
// of truth; the console copy is just a deploy target.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
